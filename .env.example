# ==========================================
# Intelliview AI - Environment Config
# ==========================================

# ----------------------------
# Backend Config (FastAPI)
# ----------------------------
PORT=8000
DATABASE_MODE=auto # 'auto' | 'firebase' | 'local'

# Groq API Configuration
# Get a free API key at: https://console.groq.com/keys
GROQ_API_KEY="your_groq_api_key"

# Firebase Admin SDK Configuration (Optional - only required if DATABASE_MODE=firebase)
FIREBASE_CREDENTIALS_PATH=backend/service_account.json
# Or specify stringified credentials JSON direct:
# FIREBASE_CREDENTIALS_JSON={"type": "service_account", ...}

# ----------------------------
# Frontend Config (Next.js)
# ----------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Firebase Client SDK Configuration (Optional - only required for real authentication)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id



